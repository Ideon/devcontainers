# NOT tracked — add to .gitignore in your project:
#   .devcontainer/local.env
#
# Copy this file to .devcontainer/local.env and fill in your keys.
# It is loaded automatically by Docker Compose (required: false, so missing
# file is fine for collaborators who use different auth methods).
#
# CLI-auth tools (Claude Code, GitHub CLI) are handled via host bind-mounts
# in base.yml and do not need keys here.

# --- OpenAI ---
OPENAI_API_KEY=

# --- Anthropic (direct API access, separate from Claude Code CLI auth) ---
ANTHROPIC_API_KEY=

# --- Google AI / Gemini ---
GOOGLE_API_KEY=
GEMINI_API_KEY=

# --- Project-specific secrets below ---
